# HTTP port exposed on the host
PORT=8000

# OAuth callback port exposed on the host. ChatGPT OAuth requires container port 1455.
LOGIN_PORT=1455

# Image to run. For a local build, use: chatmock:gpt-5.5
CHATMOCK_IMAGE=chatmock:gpt-5.5

# Container auth dir. Keep /data unless you also change docker-compose.yml.
CHATGPT_LOCAL_HOME=/data

# Auth source mounted into /data:
# - default named volume: chatmock_data
# - existing host auth dir: /home/you/.codex or /home/you/.chatgpt-local
CHATMOCK_AUTH_SOURCE=chatmock_data

# Prompt file mounted into the container
CHATMOCK_PROMPT_FILE=./prompt.md

# Optional inbound API token. When set, clients must send:
# Authorization: Bearer <token>
# CHATMOCK_API_KEY=change-me

# Show request/stream logs
VERBOSE=false
VERBOSE_OBFUSCATION=false

# OAuth client id (modify only if you know what you're doing)
# CHATGPT_LOCAL_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann

# Reasoning controls
# Options: none|minimal|low|medium|high|xhigh
CHATGPT_LOCAL_REASONING_EFFORT=medium
# Options: auto|concise|detailed|none
CHATGPT_LOCAL_REASONING_SUMMARY=auto
# Options: legacy|o3|think-tags|current
CHATGPT_LOCAL_REASONING_COMPAT=think-tags
CHATGPT_LOCAL_EXPOSE_REASONING_MODELS=false

# Priority processing for supported models
CHATGPT_LOCAL_FAST_MODE=false

# Enable default web search tool
CHATGPT_LOCAL_ENABLE_WEB_SEARCH=false

# Force a specific model name
# CHATGPT_LOCAL_DEBUG_MODEL=gpt-5.5
